{
  "name": "nray",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "wrangler types && concurrently --names \"DB,SERVER\" --prefix-colors \"blue,green\" \"turso dev --port 8080\" \"node scripts/wait-for-port.mjs 127.0.0.1 8080 && npm run migrate && npx astro dev\"",
    "start": "astro dev",
    "build": "astro build",
    "email": "email dev --dir ./src/emails",
    "migrate": "kysely migrate:latest",
    "migrate:make": "kysely migrate:make",
    "migrate:list": "kysely migrate:list ",
    "migrate:types": "kysely-codegen --camel-case --singularize --out-file ./src/db/types.ts",
    "preview": "wrangler dev",
    "test": "npm run -s lint && astro check && tsc --noEmit && vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pre-commit": "npm run test -- --run",
    "lint": "eslint --max-warnings=0 \"src/**/*.{js,astro}\"",
    "astro": "astro",
    "optimize-svg": "svgo --recursive --config=.svgo.config.cjs src/blog/"
  },
  "pre-commit": [
    "pre-commit"
  ],
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "14.0.1",
    "@astrojs/db": "0.21.3",
    "@astrojs/mdx": "7.0.0",
    "@astrojs/react": "6.0.0",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@base-ui/react": "^1.6.0",
    "@expressive-code/plugin-line-numbers": "0.44.0",
    "@getbrevo/brevo": "^5.0.4",
    "@libsql/kysely-libsql": "0.4.1",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.9",
    "@tailwindcss/vite": "4.3.1",
    "astro": "7.0.3",
    "astro-expressive-code": "0.44.0",
    "astro-seo": "1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.4.0",
    "heroicons": "2.2.0",
    "kysely": "0.29.2",
    "kysely-ctl": "0.21.0",
    "lucide-react": "^1.21.0",
    "mdast-util-to-string": "4.0.0",
    "motion": "12.42.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.6.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "7.1.0",
    "rss-parser": "^3.13.0",
    "shiki": "4.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "5.3.0"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@react-email/preview-server": "5.2.10",
    "@types/eslint__js": "9.14.0",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sharp": "0.32.0",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "concurrently": "10.0.3",
    "eslint": "10.5.0",
    "eslint-plugin-astro": "2.1.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "kysely-codegen": "0.20.0",
    "playwright": "1.61.1",
    "pre-commit": "2.0.0",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-sql": "0.20.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react-email": "6.6.5",
    "shadcn": "^4.11.0",
    "svgo": "4.0.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "typescript-plugin-css-modules": "5.2.0",
    "vitest": "4.1.9",
    "vitest-browser-react": "2.2.0",
    "wrangler": "4.105.0"
  }
}
