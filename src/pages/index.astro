---
export const prerender = false;
import Layout from "@layouts/Layout.astro";
import avatar from "@assets/images/avatar.jpg";
import { getPosts } from "@src/api";
import Article from "@components/Article.astro";
import { Image } from "@components/Image/index.astro";
import LaunchAuditCta from "@components/LaunchAuditCta.astro";
const posts = await getPosts();
const initialPostCount = 12;
const remainingPostCount = Math.max(posts.length - initialPostCount, 0);
const title = "Nicholas Ray";
---

<Layout
  title={title}
  description="Web development tips that improve page speed, user happiness, and business success"
  openGraph={{
    basic: {
      title,
      type: "website",
      image: new URL("/avatar.jpg", Astro.url),
    },
    image: {
      alt: "Profile picture of Nicholas Ray",
      // Needed to prevent Astro SEO from outputting blank height tag.
      height: null,
    },
  }}
  twitter={{
    card: "summary_large_image",
  }}
>
  <main
    class="mx-auto max-w-2xl space-y-16 overflow-hidden px-4 pt-16 sm:space-y-24 sm:px-6 md:space-y-24 md:px-8 lg:pt-20"
  >
    <section>
      <div class="flex items-center gap-x-4">
        <div>
          <h1 class="text-foreground text-4xl font-extrabold tracking-tight">
            Hi, I'm Nick Ray
          </h1>
          <p class="text-muted-foreground mt-6 text-lg lg:text-2xl">
            I help people launch fast, accessible, and reliable web apps.
          </p>
        </div>
        <div class="flex shrink-0 items-center">
          <Image
            class="w-[80px] rounded-full md:w-[100px]"
            src={avatar}
            widths={[120, 240]}
            sizes="120px"
            alt="Avatar of Nicholas Ray"
          />
        </div>
      </div>
      <LaunchAuditCta class="mt-10" />
    </section>
    <section>
      <h2 class="text-foreground relative text-3xl font-bold tracking-tight">
        Latest Posts
      </h2>
      <ul
        class="mt-8 space-y-14 md:grid md:grid-cols-[repeat(auto-fill,minmax(350px,1fr))] md:space-y-0 md:gap-x-9 md:gap-y-16"
      >
        {
          posts.map((post, index) => (
            <li
              hidden={index >= initialPostCount}
              data-home-post-extra={
                index >= initialPostCount ? "true" : undefined
              }
            >
              <Article post={post} />
            </li>
          ))
        }
      </ul>
      {
        remainingPostCount > 0 && (
          <button
            type="button"
            class="border-border text-foreground hover:bg-muted mt-10 inline-flex h-9 items-center justify-center rounded-md border px-4 text-sm font-medium transition-colors"
            data-home-posts-show-more
          >
            Show {remainingPostCount} more posts
          </button>
        )
      }
    </section>
  </main>
</Layout>

<script>
  const showMorePostsButton = document.querySelector<HTMLButtonElement>(
    "[data-home-posts-show-more]"
  );
  const extraPosts = document.querySelectorAll<HTMLElement>(
    "[data-home-post-extra]"
  );

  showMorePostsButton?.addEventListener("click", () => {
    extraPosts.forEach((post) => {
      post.hidden = false;
    });

    showMorePostsButton.hidden = true;
  });
</script>
